{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch from scratch",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/${relativeFileDirname}/ns3-dev-${fileBasenameNoExtension}-${input:buildType}",
            
            "args": ["single_sim_db963.json", "db.json"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${workspaceFolder}/build/lib/"
                },
                //custom
                // {
                //     "name": "NS_LOG",
                //     "value": "UdpEchoClientApplication=level_all|prefix_func:UdpEchoServerApplication=level_all|prefix_func"
                // }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
    ],
    "inputs": [
        {
            "type": "pickString",
            "id": "buildType",
            "description": "What is the build option?",
            "options": [
                "debug",
                "default",
                "optimized",
                "release",
                "minsizerel"
            ],
            "default": "default"
        }
    ]
}
